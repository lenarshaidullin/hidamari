---
import { data } from '../../data/data';
import '../../styles/blocks/_faq-block.scss';

interface FaqItem {
  title: string;
  description: string;
}

interface Props {
  id?: string;
  pretitle?: string;
  title?: string;
  description?: string;
  faqItems: FaqItem[];
}

const { 
  id, 
  class: className = '', 

  pretitle,
  title, 
  description,

  faqItems =[]
} = Astro.props;

---

<div class={`faq-block ${className}`} id={id || undefined}>
  <div class="container">

    <div class="row">
      <div class="c-12 c-md-10 m-md-1">
        {pretitle &&(
          <div class="pretitle text--center mb-16">
            <slot name="pretitle">{pretitle}</slot>
          </div>
        )}
        {title &&(
          <h2 class="title-h2 text--center">
            <slot name="title">{title}</slot>
          </h2>
        )}
        {description &&(
          <div class="mw-wrapper mw-wrapper--center mt-16">
            <p class="text--center">{description}</p>
          </div>
        )}
      </div>
    </div>

    <div class={`row ${title || description ? 'mt-48' : ''}`}>
      <div class="c-12 c-sm-10 m-sm-1 c-md-8 m-md-2">
        <div class="faq">
          {faqItems.map((faqItem, index) => (
            <div key={index} class="faq-item">
              <div class="faq-item__title"><span class="title-h5">{faqItem.title}</span><span class="icon"></span></div>
              <div class="faq-item__content">
                <div class="text--default">
                  <p>{faqItem.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="text--center mt-48">Есть вопрос? Свяжитесь с нами в соцсетях</p>
        <div class="buttons-wrapper buttons-wrapper--jcc mt-24">
          <a href={data.social.telegramChannel} class="button button--icon button--icon--telegram"></a>
          <a href={data.social.max} class="button button--icon button--icon--max"></a>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.querySelectorAll('.faq-item').forEach(item => {
    const title = item.querySelector('.faq-item__title');
    const content = item.querySelector('.faq-item__content');

    if (!title || !content) return;

    title.addEventListener('click', () => {
      const isActive = title.classList.toggle('active');
      content.classList.toggle('active', isActive);
      content.style.maxHeight = isActive ? `${content.scrollHeight}px` : '0';
    });
  });
</script>
