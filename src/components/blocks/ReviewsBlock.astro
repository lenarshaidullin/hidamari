---
import '../../styles/blocks/_reviews-block.scss';

interface Review {
  images?: string[];
  title?: string;
  description?: string;

  author?: string;
  sourceLink?: string;
  sourceText?: string;
}

interface Props {
  id?: string;
  class?: string;

  pretitle?: string;
  title?: string;
  description?: string;

  reviews: Review[];
}

const { 
  id, 
  class: className = '', 

  pretitle,
  title, 
  description,

  reviews =[]
} = Astro.props;

---

<div class={`reviews-block ${className}`} id={id || undefined}>
  <div class="container">

    <div class="row">
      <div class="c-12 c-md-10 m-md-1">
        {pretitle &&(
          <div class="pretitle text--center mb-16">
            <slot name="pretitle">{pretitle}</slot>
          </div>
        )}
        {title &&(
          <h2 class="title-h2 text--center">
            <slot name="title">{title}</slot>
          </h2>
        )}
        {description &&(
          <div class="mw-wrapper mw-wrapper--center mt-16">
            <p class="text--center">{description}</p>
          </div>
        )}
      </div>
    </div>

    <div class={`row ${title || description ? 'mt-48' : ''}`}>
      <div class="c-12">
        <div class="cards">
          <div class="swiper swiper-reviews-block">
            <div class="swiper-wrapper">
              {reviews.map((review, index) => (
                <div class="swiper-slide">
                  <div class="card card--with-wrapper">
                    {review.images && (
                      <div class="card__images-wrapper mb-24">
                        {review.images?.map(img => ( 
                          <img src={img} alt={review.title} /> 
                        ))}
                      </div>
                    )}
                    {review.title &&( <div class="title-h5 mb-16">{review.title}</div> )}
                    <p>{review.description}</p>
                    {review.author && ( <p class="text--small mt-16">{review.author}</p> )}
                  </div>
                </div>
              ))}
            </div>
            <div class="swiper-pagination"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-48">
      <div class="c-12">
        <div class="buttons-wrapper buttons-wrapper--jcc buttons-wrapper--ew">
          <a href="/otzyvy/" class="button button--outlined--gray" target="_blank">Все отзывы</a>     
        </div>
      </div>
    </div>

  </div>
</div>

<script client:load>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.swiper-reviews-block').forEach(el => {
      if (el.classList.contains('swiper-initialized')) return;
      new Swiper(el, {
        autoHeight: true,
        pagination: { el: '.swiper-pagination', clickable: true },
        breakpoints: {
          0:    { slidesPerView: 1.1, slidesPerGroup: 1, spaceBetween: 8 },
          767:  { slidesPerView: 2.1, slidesPerGroup: 2, spaceBetween: 8 },
          1041: { slidesPerView: 3.1, slidesPerGroup: 3, spaceBetween: 8 },
        },
      });
    });
  });
</script>
