---
import { data } from '../../data/data';
---

<header class="header" id="top">
  <div class="container">
    <div class="row">
      <div class="c-12">
        <div class="nav">
          <div class="nav__logo">
            <a href="/" class="pretitle">hidamari</a>
          </div>
          <div class="nav__links-wrapper">
            <div class="nav__links">
              <!-- <a href="/o-proekte/">О проекте</a> -->
              <a href="/izdeliya/">Изделия</a>
              <!-- <a href="/portfolio/">Портфолио</a> -->
              <!-- <a href="/otzyvy/">Отзывы</a> -->
              <a href="/kontakty/">Контакты</a>
            </div>
          </div>
          <div class="nav__buttons">
            <div class="buttons-wrapper">
              {data.social.telegramChannel && (
                <a href={data.social.telegramChannel} class="button--icon button--icon--telegram"></a>
              )}
              {data.social.max && (
                <a href={data.social.max} class="button--icon button--icon--max"></a>
              )}
            </div>
            <div class="hamburger">
              <span class="line"></span>
              <span class="line"></span>
              <span class="line"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburger = document.querySelector('.hamburger');
    const linksWrapper = document.querySelector('.nav__links-wrapper');

    if (!hamburger || !linksWrapper) return;

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      linksWrapper.classList.toggle('active');
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('.nav__links-wrapper') && !e.target.closest('.hamburger')) {
        linksWrapper.classList.remove('active');
        hamburger.classList.remove('active');
      }
    });
  });
</script>