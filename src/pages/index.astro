---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderBlockType1 from '../components/blocks/HeaderBlockType1.astro';
import CardsBlockType1 from '../components/blocks/CardsBlockType1.astro';
import CardsBlockType2 from '../components/blocks/CardsBlockType2.astro';
import BlockquoteBlockType1 from '../components/blocks/BlockquoteBlockType1.astro';
import FaqBlock from '../components/blocks/FaqBlock.astro';
import CtaBlockType1 from '../components/blocks/CtaBlockType1.astro';
import ProductsBlock from '../components/blocks/ProductsBlock.astro';
---

<BaseLayout title="Главная">

  <HeaderBlockType1
    id=""
    class=""

    subtitle="Столярная мастерская"
    title="Предметы ручной работы, которые хочется оставить рядом надолго"
    description="Уникальные изделия из массива дерева ручной работы. Натуральные материалы, внимание к деталям и безупречное качество"
    >
    <div class="buttons-wrapper buttons-wrapper--jcc mt-48">
      <a href="#" class="button scroll-to">Выбрать изделие</a>
    </div>
  </HeaderBlockType1>

  <CardsBlockType2
    id=""
    class="pt-64 pt-sm-96 pt-md-128"

    subtitle=""
    title=""
    description=""

    cards={[
      {
        image: "https://hidamari.ru/wp-content/uploads/ff261b.jpg",
        title: "Что такое Hidamari?",
        description: "Hidamari — это японское слово, означающее солнечное пятно на полу. Это тихое уютное ощущение, которое хочется продлить. Такими мы создаём наши изделия: не кричащими, не требующими внимания, а просто тёплыми местами в вашем доме. Мы верим, что в мире цифрового шума важно окружать себя подлинными вещами. Такими, которые стареют красиво, приобретая благородную патину времени и сохраняя историю прикосновений.",
        link: "#"
      },
    ]}
    >
  </CardsBlockType2>

  <CardsBlockType1
    id=""
    class="pt-64 pt-sm-96 pt-md-128"

    subtitle="Наши"
    title="Преимущества"
    description=""

    cards={[
      {
        title: "Материалы",
        description: "Дуб, ясень, бук, орех - только массив, без шпона и имитаций"
      },
      {
        title: "Защита",
        description: "Покрытие натуральными составами: масло, воск"
      },
      {
        title: "Гарантия",
        description: "Отвечаем за каждое изделие, если возникнет вопрос — найдём решение без бюрократии"
      },
      {
        title: "Упаковка",
        description: "Надёжно упаковываем каждое изделие: пупырка, картон, стрейч-пленка"
      },
    ]}
    >
  </CardsBlockType1>

  <BlockquoteBlockType1
    id=""
    class="mt-64 mt-sm-96 mt-md-128"
    blockquoteText="«Дерево — материал, который становится красивее, когда стареет. Оно хранит тепло рук и свет солнца. Именно поэтому вещи из дерева не просто служат — они живут вместе с вами. И с каждым годом обретают особый характер, свою историю.»"
    blockquoteAuthor="- Команда проекта Hidamari -"
    >
  </BlockquoteBlockType1>

  <CardsBlockType2
    id=""
    class="pt-64 pt-sm-96 pt-md-128"

    subtitle="Наш подход"
    title="Внимание к каждой детали"
    description=""

    cards={[
      {
        image: "https://hidamari.ru/wp-content/uploads/ff261b.jpg",
        title: "Заголовок",
